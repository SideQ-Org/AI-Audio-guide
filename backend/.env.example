# Copy to .env and fill in OPENAI_API_KEY. Never commit .env (it holds the key).
# These are the production-ready values for a real walk (cloud LLM + real OSM + facts).

# --- LLM: OpenRouter -> DeepSeek V3 on all roles ----------------------------
# IMPORTANT (region block): OpenRouter geo-blocks OpenAI / Anthropic / Google
# (Gemini) from some host regions (e.g. RU) -> every call returns HTTP 403
# "This model is not available in your region." DeepSeek V3 is reachable there
# and handles strict json_schema (Scorer) + multilingual narration well, so it
# is the production default. On an unrestricted host you may switch OPENAI_MODEL
# back to google/gemini-3.5-flash (then restore the reasoning cap below).
AGENT_BACKEND=openai
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=                       # sk-or-... (required)
OPENAI_MODEL=deepseek/deepseek-chat   # FREE tier model (also the default when tiers are off)
OPENAI_MODEL_SCORER=
OPENAI_MODEL_NARRATOR=
OPENAI_MODEL_COMPANION=
OPENAI_MODEL_LANDMARK=
OPENAI_MODEL_ENRICHER=
# PAID tier model (feature: account tiers). Paid sessions use this on every role;
# empty => tiers OFF (everyone gets OPENAI_MODEL). Reasoning cap below applies to the
# paid model only (DeepSeek free tier is non-reasoning, so it's never sent the param).
OPENAI_MODEL_PAID=google/gemini-3.5-flash
# DeepSeek V3 is not a reasoning model -> leave the cap off (ignored anyway).
# (For Gemini set EFFORT=low and MAX_TOKENS=64 to keep its CoT out of the prose.)
OPENAI_REASONING_EFFORT=low
OPENAI_REASONING_MAX_TOKENS=64
OPENAI_PROMPT_CACHE=true
OPENAI_PRICE_IN_PER_MTOK=0.3          # FREE (DeepSeek) ballpark; provider-reported cost is authoritative
OPENAI_PRICE_OUT_PER_MTOK=0.9
OPENAI_PRICE_IN_PER_MTOK_PAID=1.5     # PAID (Gemini 3.5 Flash) ballpark for the fallback estimator
OPENAI_PRICE_OUT_PER_MTOK_PAID=9.0
USD_SESSION_BUDGET=25                 # soft warning only — set a hard cap in the OpenRouter dashboard

# Anthropic (only if AGENT_BACKEND=anthropic)
ANTHROPIC_API_KEY=

# --- Geo: real places from OpenStreetMap ------------------------------------
GEO_SOURCE=overpass                   # MUST be "overpass" for a real walk ("fixture" = Red Square demo only)
# Public overpass-api.de is often rate-limited/blocked; this mirror is reliable:
OVERPASS_URL=https://maps.mail.ru/osm/tools/overpass/api/interpreter
# For production/high load: point OVERPASS_URL at a PAID or SELF-HOSTED Overpass (the public
# mirrors are a single point of failure) and optionally list comma-separated backups here.
OVERPASS_MIRRORS=

# --- Fact enrichment: real WebSearch (OpenRouter web plugin) -----------------
ENRICHMENT_SOURCE=websearch           # "mock" = fixtures (offline/tests)
WEB_SEARCH_MAX_RESULTS=2              # web results per place (OpenRouter bills per result)
WEB_SEARCH_MAX_TOKENS=400
ENRICH_TOP_K=2
ENRICH_TIMEOUT_S=9.0                  # web search needs ~5-7s; too low => no facts, only names
ENRICH_MIN_WEIGHT=0.0                # wiki facts are free; gates only the PAID fallback for
                                     # non-wiki places (0 = search all; raise to save cost)
ENRICH_CACHE_PATH=.enrich_cache.json  # docker-compose overrides this to a volume path

# --- STT (voice barge-in) ---------------------------------------------------
# "openrouter" = cloud Whisper via the OpenAI-compatible /audio/transcriptions (~3 s, reuses the
# OpenRouter creds above) — MUCH faster than local CPU Whisper (~8-10 s); this is what prod uses.
# "faster_whisper" = local CPU/GPU. "mock" = canned transcript (tests, no model download).
STT_BACKEND=openrouter
STT_MODEL=mistralai/voxtral-mini-transcribe   # perfect Russian, no geoblock (openai/* 403s in some
#                                             # regions); check {base}/models?output_modalities=transcription
# STT_API_KEY= / STT_BASE_URL=        # override only to send STT to a different provider than the LLM
# --- local Whisper (only when STT_BACKEND=faster_whisper) ---
WHISPER_MODEL_SIZE=small              # tiny|base|small|medium — smaller = faster on CPU
WHISPER_DEVICE=cpu                    # "cuda" needs a GPU + CUDA libs in the image
WHISPER_COMPUTE_TYPE=int8

# --- Revisit (loop back to a place told earlier -> a fresh detail) ----------
# REVISIT_ENABLED=true
# REVISIT_RADIUS_M=60                  # how close counts as "back at the object"
# REVISIT_MIN_ROUTE_M=250             # route walked since telling it before a revisit can fire

# --- Neural TTS (optional, PAID tier): server-side voice --------------------
# OFF by default (TTS_BACKEND=null => client speaks with on-device flutter_tts). When ON,
# PAID sessions get a neural voice synthesized here and attached to the narration frame.
# Reuses your OpenRouter creds above (OPENAI_API_KEY/OPENAI_BASE_URL) — OpenRouter now proxies
# /audio/speech — so you usually only need the next two lines:
# TTS_BACKEND=openai
# TTS_MODEL=x-ai/grok-voice-tts-1.0   # mp3 over OpenRouter, works in geoblocked regions (OpenAI TTS
#                                     # is cut off in prod). List: {base}/models?output_modalities=speech
# TTS_VOICE=Ara                       # Grok voices: Eve/Ara/Rex/Sal/Leo (OpenAI uses alloy/nova/sage)
# TTS_FORMAT=mp3                      # mp3 plays on both iOS & Android (opus/ogg is flaky on iOS)
# TTS_TIMEOUT_S=8.0
# TTS_TIER_MIN=paid                   # min tier that gets neural audio ("free" => everyone)
# TTS_CACHE_PATH=.tts_cache           # dir of cached audio blobs ("" => memory only)
# TTS_PRICE_PER_MCHAR=12.0            # USD per 1M chars, for the cost meter / hard cap
# TTS_API_KEY= / TTS_BASE_URL=        # override ONLY to send TTS to a different provider than the LLM

# --- Behaviour --------------------------------------------------------------
DEFAULT_LANGUAGE=ru                   # the app overrides this per session anyway
DEFAULT_RADIUS_M=80
MAX_RADIUS_M=500

# State store: empty => in-memory; otherwise a redis url e.g. redis://localhost:6379/0
REDIS_URL=
SESSION_TTL_S=3600                     # evict idle in-memory sessions after this (0 = never)
MAX_SESSIONS=2000                     # LRU cap on in-memory sessions (0 = unbounded)

# --- Security & spend limits (protect the public /ws) -----------------------
# Shared access token for /ws. Empty => OPEN (dev). In prod set a long random value;
# the clients must be (re)built with the SAME token (WS_TOKEN dart-define / injected
# into the web client) — back end + clients roll out together.
WS_TOKEN=
MAX_CONNECTIONS_PER_IP=8               # concurrent WS per IP. Raise (~32) while testers share a NAT.
# Hard spend ceiling (USD, cumulative process spend). 0 = off. Once hit, LLM calls
# are blocked (guide goes silent) — in-app backstop on top of the OpenRouter dashboard cap.
# STRONGLY RECOMMENDED on any public/paid deploy: the /ws is open, so without a cap an
# abuser can drive unbounded LLM/web-search cost. Set a value AND a monthly cap on the
# provider dashboard. The backend logs a warning at startup when this is 0 on a paid backend.
USD_HARD_CAP=0
MAX_UTTERANCE_CHARS=2000
MAX_AUDIO_B64_CHARS=8000000           # ~6 MB decoded audio clip ceiling
MAX_WS_FRAME_CHARS=8065536            # hard cap on one inbound WS frame (pre-parse, anti-DoS)
STATS_TOKEN=                          # admin token for GET /stats; empty => /stats disabled
# Trust X-Forwarded-For for the client IP. Keep FALSE for direct/LAN/dev (XFF is
# client-spoofable). Set TRUE in prod BEHIND CADDY so per-IP limits see real client IPs.
TRUST_PROXY=false
# Inbound WS message rate limit (per-connection token bucket). Generous vs a real walk,
# tight vs a flood. WS_MSGS_PER_SEC=0 disables the limiter.
WS_MSGS_PER_SEC=20
WS_MSG_BURST=40

# --- Accounts & walk history (durable layer + Supabase auth) -----------------
# All empty => accounts OFF: every session is a guest, nothing is written (MVP path).
# See backend/db/README.md for the local supabase-CLI dev stack + migrations.
# Durable store (SQLAlchemy async URL). Local supabase stack default shown:
DATABASE_URL=                         # postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
DB_ECHO=false
# WS auth: verify the client's Supabase JWT. Set a JWKS URL (recommended) and/or the
# legacy HS256 secret. Empty => auth disabled (guest-only).
SUPABASE_JWKS_URL=                    # https://<proj>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=                  # legacy HS256 project secret (fallback)
SUPABASE_JWT_AUD=authenticated        # expected `aud` claim

# --- Free/paid tier limits (feature: account tiers) -------------------------
# Free accounts are cost-capped (DeepSeek + wiki-only facts + ads) so they stay ≈
# ad-revenue-neutral; paid (Gemini + web facts, no ads) is uncapped. 0 => unlimited.
FREE_TIER_DAILY_TOURS=2               # new walks a free user may start per rolling 24h
FREE_TIER_WALK_LIMIT=10               # saved walks kept for a free user (oldest evicted past this)

# --- Billing: subscription receipt verification (feature: account tiers) ------
# Google Play verifies purchase tokens before granting the paid tier. Empty =>
# /billing returns 503. Product ids must match the Play Console + the client.
GOOGLE_PLAY_PACKAGE=                  # e.g. com.yourco.aiguide
GOOGLE_SERVICE_ACCOUNT_JSON=         # path to the Play Developer API service-account key
BILLING_PRODUCT_MONTHLY=premium_monthly
BILLING_PRODUCT_YEARLY=premium_yearly
